HOST=0.0.0.0
PORT=10000
ADMIN_AUTH_KEY=change-me-admin-key

# MCP auth mode:
# - oauth: MCP OAuth 2.1 / GitHub login flow
# - key: static bearer-style key for SSH-only or private deployments
MCP_AUTH_MODE=oauth
# Required when MCP_AUTH_MODE=key
# MCP_AUTH_KEY=change-me-mcp-key

# Optional public URL override. On Render this defaults to RENDER_EXTERNAL_URL.
# PUBLIC_BASE_URL=https://your-service.onrender.com

# Optional initial allowlist seed used only on first boot.
# INITIAL_GITHUB_ALLOWED_USERS=riatzukiza

# Optional local dev helpers.
# DATA_DIR=./data
# AUTO_APPROVE=true
# ALLOW_UNAUTH_LOCAL=false
